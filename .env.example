# WhatsApp Chat Fragmenter - Environment Configuration

# Web Server
PORT=3000
HOST=localhost

# Output Settings
OUTPUT_DIR=./output
MAX_FILE_SIZE=2147483648

# Parser Settings
DETECT_FORMAT_AUTO=true
SKIP_SYSTEM_MESSAGES=true
SKIP_MEDIA_MESSAGES=true

# Logging
VERBOSE=false
DEBUG=false
LOG_LEVEL=info

# Feature Flags
ENABLE_WEB_UI=true
ENABLE_CLI=true
ENABLE_INDEX_GENERATION=true
